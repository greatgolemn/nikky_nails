{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "A salon store (tenant) registered on the NailSaaS platform",
      "type": "object",
      "properties": {
        "shopName": { "type": "string", "description": "Store display name" },
        "shopPhone": { "type": "string", "description": "Store phone number" },
        "ownerId": { "type": "string", "description": "Firebase Auth UID of the store owner" },
        "subscription": {
          "type": "object",
          "properties": {
            "plan": { "type": "string", "enum": ["trial", "basic", "pro"] },
            "status": { "type": "string", "enum": ["active", "expired", "cancelled"] },
            "maxMembers": { "type": "number" },
            "startedAt": { "type": "string", "format": "date-time" },
            "expiresAt": { "type": "string", "format": "date-time" }
          }
        },
        "lineConfig": {
          "type": "object",
          "properties": {
            "channelAccessToken": { "type": "string" },
            "channelSecret": { "type": "string" },
            "webhookUrl": { "type": "string" }
          }
        },
        "theme": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "logoUrl": { "type": "string" }
          }
        },
        "isActive": { "type": "boolean", "description": "Whether the store is currently active" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopName", "ownerId", "isActive"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Platform user profile linked to Firebase Auth",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "store_owner", "staff"] },
        "tenantId": { "type": "string", "description": "The tenant this user belongs to (null for super_admin)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "Staff invitation sent by a store owner",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["store_owner", "staff"] },
        "invitedBy": { "type": "string", "description": "UID of the inviter" },
        "status": { "type": "string", "enum": ["pending", "accepted", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "email", "role", "status"]
    },
    "Member": {
      "title": "Member",
      "description": "Salon member information and loyalty status",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string", "description": "The tenant this member belongs to" },
        "name": { "type": "string", "description": "Customer name" },
        "phone": { "type": "string", "description": "Phone number used for identification" },
        "points": { "type": "number", "description": "Current loyalty points balance" },
        "totalSpent": { "type": "number", "description": "Aggregate spending amount for tiering" },
        "tier": { "type": "string", "enum": ["Bronze", "Silver", "Gold"], "description": "Membership level" },
        "preferredBranchId": { "type": "string", "description": "ID of the branch where the member registered" },
        "lineUserId": { "type": "string", "description": "Unique identifier for LINE OA" },
        "lineDisplayName": { "type": "string", "description": "Display name from LINE profile" },
        "lastVisit": { "type": "string", "format": "date-time", "description": "Timestamp of the last salon visit" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the member was registered" }
      },
      "required": ["tenantId", "name", "phone", "points", "tier"]
    },
    "Package": {
      "title": "Package",
      "description": "Prepaid salon services or subscription packages",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "memberId": { "type": "string", "description": "Reference to the owner member" },
        "title": { "type": "string", "description": "Package name (e.g., Gel Polish x10)" },
        "totalSessions": { "type": "number", "description": "Original session count" },
        "remainingSessions": { "type": "number", "description": "Current sessions left" },
        "expiryDate": { "type": "string", "format": "date-time", "description": "When the package expires" },
        "status": { "type": "string", "enum": ["active", "expired", "depleted"] }
      },
      "required": ["tenantId", "memberId", "title", "totalSessions", "remainingSessions", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Record of points, spending, or package usage",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "memberId": { "type": "string", "description": "Reference to the member" },
        "type": { "type": "string", "enum": ["point_earn", "point_redeem", "package_buy", "package_use"] },
        "amount": { "type": "number", "description": "Currency amount if applicable" },
        "pointsChange": { "type": "number", "description": "Points added or subtracted" },
        "serviceName": { "type": "string", "description": "Name of service performed" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "memberId", "type", "timestamp"]
    },
    "PackageTemplate": {
      "title": "PackageTemplate",
      "description": "Pre-defined package options created by store owner",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "sessions": { "type": "number" }
      },
      "required": ["tenantId", "title", "price", "sessions"]
    },
    "ServiceTemplate": {
      "title": "ServiceTemplate",
      "description": "Pre-defined standard salon services",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" }
      },
      "required": ["tenantId", "name", "price"]
    },
    "ShopConfig": {
      "title": "ShopConfig",
      "description": "Per-tenant salon settings and branding",
      "type": "object",
      "properties": {
        "shopName": { "type": "string" },
        "shopPhone": { "type": "string" },
        "businessHours": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string" },
              "open": { "type": "string" },
              "close": { "type": "string" },
              "isOpen": { "type": "boolean" }
            }
          }
        },
        "theme": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "logoUrl": { "type": "string" }
          }
        }
      },
      "required": ["shopName"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Salon branch location details",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string", "description": "Branch name (e.g., Siam, Asoke)" },
        "phone": { "type": "string", "description": "Direct contact for this branch" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name", "lat", "lng"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Customer appointment reservation",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "memberPhone": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timeSlot": { "type": "string" },
        "branchId": { "type": "string" },
        "branchName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "memberId", "serviceName", "date", "timeSlot", "status"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Registered salon stores on the NailSaaS platform"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Platform user profiles (linked to Firebase Auth UID)"
    },
    "/invitations/{inviteId}": {
      "schema": "Invitation",
      "description": "Staff invitation records"
    },
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Salon customers partitioned by tenantId"
    },
    "/packages/{packageId}": {
      "schema": "Package",
      "description": "Individual member packages partitioned by tenantId"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Visit and loyalty history logs partitioned by tenantId"
    },
    "/packageTemplates/{templateId}": {
      "schema": "PackageTemplate",
      "description": "Available package templates per tenant"
    },
    "/serviceTemplates/{templateId}": {
      "schema": "ServiceTemplate",
      "description": "Available standard services per tenant"
    },
    "/shopConfig/{tenantId}": {
      "schema": "ShopConfig",
      "description": "Salon configuration keyed by tenantId"
    },
    "/branches/{branchId}": {
      "schema": "Branch",
      "description": "Salon branch locations per tenant"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Customer appointment records per tenant"
    }
  }
}
